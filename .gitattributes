# Repository line-ending policy.
* text=auto
.gitattributes text eol=lf
.gitignore     text eol=lf

# Portable source, scripts, and documentation use LF.
*.c      text eol=lf
*.h      text eol=lf
*.cpp    text eol=lf
*.hpp    text eol=lf
*.cc     text eol=lf
*.hh     text eol=lf
*.cmake  text eol=lf
CMakeLists.txt text eol=lf
*.json   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.md     text eol=lf
*.txt    text eol=lf
LICENSE  text eol=lf
NOTICE   text eol=lf
*.conf   text eol=lf
*.pos    text eol=lf
*.obs    text eol=lf
*.nav    text eol=lf
*.sp3    text eol=lf
*.clk    text eol=lf
*.ionex  text eol=lf
*.stec   text eol=lf
*.sh     text eol=lf
makefile text eol=lf
Makefile text eol=lf
*.mk     text eol=lf

# Windows project and batch files use CRLF.
*.bat     text eol=crlf
*.cmd     text eol=crlf
*.sln     text eol=crlf merge=union
*.vcproj  text eol=crlf
*.vcxproj text eol=crlf
*.cbproj  text eol=crlf
*.groupproj text eol=crlf
*.local   text eol=crlf
*.dfm     text eol=crlf
*.bpr     text eol=crlf

# Custom for Visual Studio.
*.cs     diff=csharp
*.csproj merge=union
*.vbproj merge=union
*.fsproj merge=union
*.dbproj merge=union

# Binary artifacts and resources.
*.bmp binary
*.ico binary
*.res binary
*.gif binary
*.jpg binary
*.jpeg binary
*.png binary
*.pdf binary
*.dll binary
*.exe binary
*.lib binary
*.obj binary
*.pdb binary
*.zip binary
*.7z  binary

# Receiver command examples may contain device-specific line endings/spacing.
data/*.cmd binary
